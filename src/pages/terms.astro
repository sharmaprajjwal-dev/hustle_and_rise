---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout 
  title="Terms of Service | Hustle & Rise" 
  description="Read Hustle & Rise's terms of service. By using our site and community, you agree to these terms."
>
  <section class="py-20 px-4 sm:px-6 lg:px-8 pt-32" style="background: #0f172a;">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-brand text-4xl sm:text-5xl font-bold mb-4 text-white tracking-wide">Terms of Service</h1>
      <p class="text-white/50 text-sm mb-12">Last updated: January 2025</p>

      <div class="prose prose-invert prose-sm max-w-none">
        <h2 class="font-brand text-2xl font-bold mt-10 mb-4 text-white tracking-wide">1. Agreement to Terms</h2>
        <p class="text-white/70 mb-6">
          By accessing and using Hustle & Rise (the "Site," "Community," or "Service"), you accept and agree to be bound by the terms and conditions of this agreement. If you do not agree, please do not use this service.
        </p>

        <h2 class="font-brand text-2xl font-bold mt-10 mb-4 text-white tracking-wide">2. User Responsibility</h2>
