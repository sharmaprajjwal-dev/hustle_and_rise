---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Page Not Found | Hustle & Rise" description="The page you're looking for doesn't exist. Get back on track and keep building.">
  <section class="relative min-h-screen flex items-center justify-center py-20 dark-gradient">
    <!-- Animated grid background -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, #00d9ff 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="relative z-10 max-w-2xl mx-auto px-4 text-center">
      <!-- 404 Display -->
      <div class="mb-8">
        <h1 class="font-brand text-9xl sm:text-[12rem] font-900 leading-none mb-6 tracking-tighter" style="background: linear-gradient(135deg, #00d9ff 0%, #0ff7ff 50%, #00a8cc 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
          404
        </h1>
        <p class="text-white/50 text-lg">You've hit a dead link in the funnel.</p>
      </div>

      <!-- Message -->
      <div class="mb-12">
        <h2 class="font-brand text-3xl sm:text-4xl font-bold text-white mb-4 tracking-wide">Page Not Found</h2>
        <p class="text-white/70 text-lg leading-relaxed max-w-xl mx-auto">
          The page you're looking for doesn't exist. It might have been moved, or the URL was entered incorrectly. Don't let this detour stop your hustle—let's get you back on track.
        </p>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <a href="/" class="btn-electric">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          Back to Home
        </a>
        <a href="/blog" class="btn-outline-electric">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
          </svg>
          Read Articles
        </a>
      </div>

      <!-- Helpful links -->
      <div class="border-t border-white/10 pt-12">
        <p class="text-white/50 text-sm mb-6">Popular Pages:</p>
        <div class="flex flex-wrap gap-4 justify-center">
          {[
            { label: "Home", href: "/" },
            { label: "Blog", href: "/blog" },
            { label: "About", href: "/about" },
            { label: "Community", href: "#" },
            { label: "Contact", href: "/contact" },
          ].map(link => (
            <a href={link.href} class="text-white/60 hover:text-[#00d9ff] transition-colors text-sm">
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
