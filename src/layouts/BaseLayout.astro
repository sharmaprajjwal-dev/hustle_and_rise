---
import "../styles/global.css";
import Logo from "../components/Logo.astro";

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "Hustle & Rise — Learn digital income skills to scale your global income and master the financial tactics to fund your freedom.",
  image = "/og-image.jpg",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://hustleandrise.com");
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Preconnect Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <!-- HEADER / NAV -->
    <header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="main-header" style="background: rgba(15, 23, 42, 0.8); border-bottom: 1px solid rgba(0, 217, 255, 0.1);">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 md:h-20">

          <!-- Logo -->
          <a href="/" class="flex items-center gap-3 group" aria-label="Hustle & Rise Home">
            <Logo size="w-14 h-14" />
            <span class="font-brand text-lg font-bold tracking-wide text-white hidden sm:inline">HUSTLE & RISE</span>
          </a>

          <!-- Desktop Nav -->
          <nav class="hidden md:flex items-center gap-8">
            <a href="/" class="nav-link">Home</a>
            <a href="/blog" class="nav-link">Articles</a>
            <a href="/about" class="nav-link">About</a>
            <a href="/contact" class="nav-link">Contact</a>
          </nav>

          <!-- CTA + Mobile Menu -->
          <div class="flex items-center gap-4">
            <a href="#" class="hidden md:inline-flex btn-electric text-xs py-2 px-5">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6l-8 8m0 0l-8-8m8 8v8"/>
              </svg>
              Join Discord
            </a>
            <!-- Mobile hamburger -->
            <button id="mobile-menu-btn" class="md:hidden text-white p-2 rounded-none hover:bg-white/10 transition-colors" aria-label="Open menu">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <line x1="3" y1="6" x2="21" y2="6"/>
                <line x1="3" y1="12" x2="21" y2="12"/>
                <line x1="3" y1="18" x2="21" y2="18"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile Menu Dropdown -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-white/10" style="background: rgba(15, 23, 42, 0.95);">
        <nav class="max-w-7xl mx-auto px-4 py-4 flex flex-col gap-4">
          <a href="/" class="nav-link text-base py-1">Home</a>
          <a href="/blog" class="nav-link text-base py-1">Articles</a>
          <a href="/about" class="nav-link text-base py-1">About</a>
          <a href="/contact" class="nav-link text-base py-1">Contact</a>
          <a href="#" class="btn-electric w-full justify-center mt-2 text-xs py-2.5">Join Discord</a>
        </nav>
      </div>
    </header>

    <!-- PAGE CONTENT -->
    <main>
      <slot />
    </main>

    <!-- FOOTER -->
    <footer style="background: #0f172a;" class="text-white pt-16 pb-8 border-t border-white/5">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-10 pb-12 border-b border-white/10">

          <!-- Brand -->
          <div class="md:col-span-2">
            <a href="/" class="inline-flex items-center gap-3 mb-4 group">
              <Logo size="w-12 h-12" />
              <span class="font-brand text-xl font-bold tracking-wide">HUSTLE & RISE</span>
            </a>
            <p class="text-white/60 text-sm leading-relaxed max-w-sm">
              Master digital income generation, build financial systems, and develop the mindset of successful entrepreneurs reshaping their futures.
            </p>
            <div class="flex items-center gap-4 mt-6">
              <a href="https://twitter.com/hustleandrise" target="_blank" rel="noopener noreferrer" aria-label="Twitter/X" class="w-9 h-9 rounded-full border border-white/20 flex items-center justify-center hover:border-[#00d9ff] hover:text-[#00d9ff] transition-colors text-white/60">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              <a href="https://linkedin.com/company/hustleandrise" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="w-9 h-9 rounded-full border border-white/20 flex items-center justify-center hover:border-[#00d9ff] hover:text-[#00d9ff] transition-colors text-white/60">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
              <a href="https://youtube.com/@hustleandrise" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="w-9 h-9 rounded-full border border-white/20 flex items-center justify-center hover:border-[#00d9ff] hover:text-[#00d9ff] transition-colors text-white/60">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              </a>
            </div>
          </div>

          <!-- Resources -->
          <div>
            <h4 class="text-xs tracking-[0.15em] uppercase mb-5 font-semibold text-[#00d9ff]">Resources</h4>
            <ul class="flex flex-col gap-3">
              <li><a href="/blog?category=Digital%20Income" class="text-white/60 text-sm hover:text-white transition-colors">Digital Income</a></li>
              <li><a href="/blog?category=Hustler%20Finance" class="text-white/60 text-sm hover:text-white transition-colors">Hustler Finance</a></li>
              <li><a href="/blog?category=Mindset" class="text-white/60 text-sm hover:text-white transition-colors">Mindset</a></li>
              <li><a href="/blog" class="text-white/60 text-sm hover:text-white transition-colors">Blog</a></li>
              <li><a href="#" class="text-white/60 text-sm hover:text-white transition-colors">Community</a></li>
            </ul>
          </div>

          <!-- Community -->
          <div>
            <h4 class="text-xs tracking-[0.15em] uppercase mb-5 font-semibold text-[#00d9ff]">Community</h4>
            <p class="text-white/60 text-sm mb-4 leading-relaxed">Join 10K+ hustlers building income streams and dominating their niches.</p>
            <a href="https://discord.gg/hustleandrise" target="_blank" rel="noopener noreferrer" class="btn-electric justify-center text-xs py-2.5">Join Our Discord</a>
          </div>
        </div>

        <!-- Bottom bar -->
        <div class="flex flex-col md:flex-row items-center justify-between gap-4 pt-8 border-t border-white/10">
          <p class="text-white/40 text-xs">&copy; {new Date().getFullYear()} Hustle & Rise. All rights reserved.</p>
          <div class="flex flex-wrap items-center justify-center gap-4">
            <a href="/about" class="text-white/40 text-xs hover:text-white/70 transition-colors">About</a>
            <span class="text-white/20">•</span>
            <a href="/contact" class="text-white/40 text-xs hover:text-white/70 transition-colors">Contact</a>
            <span class="text-white/20">•</span>
            <a href="/privacy" class="text-white/40 text-xs hover:text-white/70 transition-colors">Privacy</a>
            <span class="text-white/20">•</span>
            <a href="/terms" class="text-white/40 text-xs hover:text-white/70 transition-colors">Terms</a>
            <span class="text-white/20">•</span>
            <a href="/rss.xml" class="text-white/40 text-xs hover:text-white/70 transition-colors">RSS</a>
          </div>
        </div>
        <p class="text-white/25 text-xs text-center mt-6">
          Disclaimer: Content on Hustle & Rise is for educational purposes. Always do your own research before making financial or business decisions.
        </p>
      </div>
    </footer>

    <script>
      // Header scroll behavior
      const header = document.getElementById('main-header');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          header?.style.setProperty('background', 'rgba(15, 23, 42, 0.95)');
          header?.style.setProperty('box-shadow', '0 4px 40px rgba(0, 217, 255, 0.08)');
        } else {
          header?.style.removeProperty('background');
          header?.style.removeProperty('box-shadow');
        }
      });

      // Trigger once on load
      if (window.scrollY > 50) {
        header?.style.setProperty('background', 'rgba(15, 23, 42, 0.95)');
        header?.style.setProperty('box-shadow', '0 4px 40px rgba(0, 217, 255, 0.08)');
      }

      // Mobile menu toggle
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      mobileMenuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });

      // Close mobile menu when clicking a nav link
      mobileMenu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu?.classList.add('hidden');
        });
      });

          </script>
<script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<script is:inline>
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", user => {
      if (!user) {
        window.netlifyIdentity.on("login", () => {
          document.location.href = "/admin/";
        });
      }
    });
    
    // Handle password recovery and invites
    window.netlifyIdentity.on("signup", () => {
      window.netlifyIdentity.close();
      document.location.href = "/admin/";
    });
  }
</script>
  </body>
</html>
