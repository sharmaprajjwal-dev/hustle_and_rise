---
export interface Props {
  title: string;
  url?: string;
}

const { title, url = Astro.url.href } = Astro.props;
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);

const socialLinks = [
  {
    name: 'X',
    label: 'X (Twitter)',
    href: `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`,
    svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>'
  },
  {
    name: 'LinkedIn',
    label: 'LinkedIn',
    href: `https://www.linkedin.com/shareArticle?mini=true&url=${encodedUrl}&title=${encodedTitle}`,
    svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>'
  },
  {
    name: 'WhatsApp',
    label: 'WhatsApp',
    href: `https://api.whatsapp.com/send?text=${encodedTitle}%20${encodedUrl}`,
    svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>'
  }
];
---

<!-- Sticky Share Buttons (Desktop Fixed Sidebar + Mobile Sticky Bottom Bar) -->

<!-- Desktop: Fixed Left Sidebar -->
<aside class="hidden lg:flex flex-col items-center gap-4 fixed left-8 top-1/2 -translate-y-1/2 z-40">
  <span class="text-xs tracking-[0.18em] uppercase font-brand font-bold text-electric [writing-mode:vertical-rl] rotate-180 mb-2">Share</span>
  <div class="w-px h-10 electric-gradient"></div>

  {socialLinks.map((link) => (
    <a
      href={link.href}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`Share on ${link.label}`}
      class="share-btn group w-11 h-11 rounded-none flex items-center justify-center border border-white/20 bg-transparent text-white hover:text-electric transition-all duration-300 hover:border-electric hover:bg-electric hover:bg-opacity-10"
    >
      <svg width="16" height="16" set:html={link.svg} />
    </a>
  ))}

  <!-- Copy Link -->
  <button
  id="copy-link-btn"
  type="button"
  data-copy-url={url}
  aria-label="Copy link"
  class="share-btn group w-11 h-11 rounded-none flex items-center justify-center border border-white/20 bg-transparent text-white hover:text-electric transition-all duration-300 hover:border-electric hover:bg-electric hover:bg-opacity-10"
>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
      <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
    </svg>
  </button>

  <div class="w-px h-10 electric-gradient mt-2"></div>
</aside>

<!-- Mobile/Tablet: Sticky Bottom Bar -->
<div class="lg:hidden fixed bottom-0 left-0 right-0 z-40" style="background: rgba(15, 23, 42, 0.98); border-top: 1px solid rgba(0, 217, 255, 0.2); backdrop-filter: blur(10px);">
  <div class="flex items-center justify-between gap-2 py-3 px-4 max-w-md mx-auto">
    <span class="text-xs tracking-[0.18em] uppercase font-brand font-bold text-electric flex-shrink-0">Share:</span>
    <div class="flex items-center gap-2 flex-1">
      {socialLinks.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Share on ${link.label}`}
          class="flex items-center justify-center w-9 h-9 rounded-none border border-white/20 text-white hover:text-electric hover:border-electric transition-all"
        >
          <svg width="14" height="14" set:html={link.svg} />
        </a>
      ))}
      <!-- Copy Link Button -->
      <button
  id="copy-link-btn-mobile"
  type="button"
  data-copy-url={url}
  aria-label="Copy link"
  class="flex items-center justify-center w-9 h-9 rounded-none border border-white/20 text-white hover:text-electric hover:border-electric transition-all"
>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<script is:inline>
  async function copyText(text) {
    if (navigator.clipboard && window.isSecureContext) {
      await navigator.clipboard.writeText(text);
      return;
    }

    // Fallback for browsers where clipboard API is unavailable
    const textArea = document.createElement("textarea");
    textArea.value = text;
    textArea.style.position = "fixed";
    textArea.style.left = "-9999px";
    textArea.style.top = "-9999px";
    document.body.appendChild(textArea);
    textArea.focus();
    textArea.select();
    document.execCommand("copy");
    textArea.remove();
  }

  function attachCopyHandler(buttonId, successIcon) {
    const button = document.getElementById(buttonId);
    if (!button) return;

    button.addEventListener("click", async (event) => {
      event.preventDefault();

      const copyUrl = button.getAttribute("data-copy-url") || window.location.href;
      const original = button.innerHTML;

      try {
        await copyText(copyUrl);
        button.innerHTML = successIcon;

        setTimeout(() => {
          button.innerHTML = original;
        }, 2000);
      } catch (err) {
        console.error("Copy failed:", err);
      }
    });
  }

  attachCopyHandler(
    "copy-link-btn",
    `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#00d9ff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`
  );

  attachCopyHandler(
    "copy-link-btn-mobile",
    `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#00d9ff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`
  );
</script>
